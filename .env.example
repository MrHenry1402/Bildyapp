# Configuración del servidor
PORT=3000
PUBLIC_URL=http://localhost:3000
NODE_ENV=development

# MongoDB Atlas
# Formato: mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
DB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# JWT — Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_al_menos_64_caracteres
JWT_REFRESH_SECRET=cambia_esto_por_otro_secreto_seguro_diferente_al_anterior

# Slack Webhook — Obtener en: api.slack.com/messaging/webhooks
# Si no se define, los logs van solo a consola
SLACK_WEBHOOK=
